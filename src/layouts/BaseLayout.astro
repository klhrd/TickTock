---
// src/layouts/BaseLayout.astro
---
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Carter+One&display=swap" rel="stylesheet">
        
        <slot name="head" />
    </head>
    <body>
        <header class="header">
            <button class="menu-btn" id="menu-btn">
                <span class="material-icons">menu</span>
            </button>
            
            <slot name="header-content" />
        </header>

        <aside id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <h3>Settings</h3>
                <div class="header-actions" id="header-actions">
                    <button class="share-btn" id="share-menu-btn">
                        <span class="material-icons">share</span>
                    </button>
                    <button class="close-btn" id="close-menu-btn">
                        <span class="material-icons">close</span>
                    </button>
                </div>
            </div>
            
            <div class="custom-menu-content">
                <slot name="custom-menu" />
            </div>

            <hr class="menu-divider" />
            <div class="director-link">
                <h3>Tools Directory</h3>
                <a href="/TickTock/">Home</a>
                <a href="/TickTock/countdown">Countdown</a>
            </div>
        </aside>

        <main class="main-container">
            <slot name="main-content" />

            <div class="overlay" id="overlay"></div>
        </main>

        <slot name="footer-content" />

        <slot name="foot-script" />

        <script>
            const sidebar=document.getElementById("sidebar");
            const overLay=document.getElementById("overlay");
            const menuBtn=document.getElementById("menu-btn");
            const closeMenuBtn=document.getElementById("close-menu-btn");

            menuBtn?.addEventListener('click',()=>
            {
                sidebar?.classList.add('open');
                overLay?.classList.add('show');
            })

            const handleClose=()=>
            {
                sidebar?.classList.remove('open');
                overLay?.classList.remove('show');
            }
            closeMenuBtn?.addEventListener('click',handleClose);
            overLay?.addEventListener('click',handleClose);

        </script>

        <style>

            body {
                background-color: #212836;
                color: #faf9db;
                margin: 0;
                padding: 0px;
                box-sizing: border-box;
            }
            /* header header header header header header header header header header */

            /*.header
            {
                position: fixed;
                left: 0;
                top: 0;
                width: 100%;
                height: 60px;
                display: flex;
                align-items: center;
                padding: 0 20px;
                box-sizing: border-box;
                z-index: 900;
            }*/

            .menu-btn
            {
                background: #c5c5c530;
                border-radius: 12px;
                border: none;
                color: #c5c5c5;
                cursor: pointer;
                padding: 5px;
                display: flex;
                align-items: center;
                justify-content: center;

                position: absolute;
                top: 12px;
                right: 15px;
            }

            .menu-btn .material-icons
            {
                font-size: 1.5rem;
            }

            /* aside aside aside aside aside aside aside aside aside aside */

            .sidebar
            {
                position: fixed;
                top: 0px;
                right: 0px;
                width: 280px;
                height: 100vh;

                color: #faf9db;
                box-shadow: -5px 0 15px #00000075;
                
                padding: 15px 20px;
                box-sizing: border-box;
                z-index: 1000;
                
                transform: translateX(100%);
                transition: transform 0.3s ease;
                
                /* added */
                background-color: #1a1f2a;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                
            }

            .sidebar.open
            {
                transform: translateX(0);
            }

            .sidebar-header
            {
                display: flex;
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 20px;
            }

            .sidebar-header h3
            {
                margin: 0px;
            }

            .header-actions
            {
                display: flex;
                flex-direction: row;
            }

            .share-btn, .close-btn
            {
                background: #c5c5c530;
                border-radius: 12px;
                border: none;
                color: #c5c5c5;
                cursor: pointer;
                padding: 5px;
                margin: 5px;
                
                display: flex;
                align-items: center;
                justify-content: center;
                transition: color 0.2s ease;
            }

            .share-btn:hover, .close-btn:hover
            {
                color: #ffffff;
            }

            .custom-menu-content
            {
                flex-grow: 1;
                padding: 0;
                overflow-y: auto;
            }

            .custom-menu-content::-webkit-scrollbar
            {
                /* 讓捲動條變細 */
                width: 6px;
            }

            .custom-menu-content::-webkit-scrollbar-track
            {
                /* 軌道透明 */
                background: transparent;
            }

            .custom-menu-content::-webkit-scrollbar-thumb
            {
                /* 滾輪主體設定為半透明白 */
                background: #ffffff20;
                border-radius: 10px;
            }

            .custom-menu-content::-webkit-scrollbar-thumb:hover
            {
                /* 滑鼠懸停時變亮一點 */
                background: #ffffff40;
            }
            .menu-divider
            {
                border: 0;
                height: 1px;
                background: #ffffff15;
                margin: 0;
            }

            .director-link
            {
                padding: 20px;
                background: #1a1f2a; /* #1a1f2a #212836 #13171f */
                margin: 0 -20px -15px -20px; /* 撐滿側邊欄底部 */
            }

            .director-link h3
            {
                font-size: 0.8rem;
                color: #555555;
                margin: 0 0 10px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .director-link a
            {
                display: block;
                color: #aaaaaa;
                margin: 10px 0;
                text-decoration: none;
                font-size: 0.95rem;
                font-family: inherit;
                transition: color 0.2s ease;

                /* 偽縮排 */
                padding-left: 25px;
            }

            .director-link a:hover
            {
                color: #fffa65;
            }

            /* main main main main main main main main main main */

            /*.main-container
            {
                width: 100%;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                box-sizing: border-box;
            }*/

            .overlay
            {
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background-color: #00000070;
                backdrop-filter: blur(5px);
                z-index: 999;

                opacity: 0;
                pointer-events: none;
                transition: opacity 0.3s ease;
            }

            .overlay.show
            {
                opacity: 1;
                pointer-events: auto;
            }
        </style>
    </body>

</html>