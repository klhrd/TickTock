---
// src/pages/countdown/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout>
    <div slot="head">
        <title>Tick Tock</title>
    </div>

    <div slot="header-content">
        <div class="title-label">
            <h1>Tick Tock</h1>
        </div>
        <div id="event-label"></div>
    </div>

    <div slot="custom-menu">
        <div class="mode-toggle-container">
            <button id="mode-full" class="mode-btn-item active">Full Mode</button>
            <button id="mode-days" class="mode-btn-item">Days Mode</button>
        </div>
        <div class="menu-item" style="margin-top: 15px;">
            <label for="date-input">Change Target Date:</label>
            <input type="date" id="date-input">
        </div>
        <div class="menu-item" style="margin-top: 15px;">
            <label for="title-input">Edit Event Title:</label>
            <input type="text" id="title-input" placeholder="New Year">
        </div>
    </div>

    <div slot="main-content" class="countdown-container">
        <section>
            <div class="time-box"><div id="years">00</div><span>years</span></div>
            <div class="time-box"><div id="months">00</div><span>months</span></div>
            <div class="time-box"><div id="days">00</div><span>days</span></div>
            <div class="time-box"><div id="hours">00</div><span>hours</span></div>
            <div class="time-box"><div id="minutes">00</div><span>minutes</span></div>
            <div class="time-box"><div id="seconds">00</div><span>seconds</span></div>
        </section>
    </div>

    <div slot="footer-content">
        <div id="target-label"></div>
    </div>

    <script slot="foot-script">
        import './script.js';
    </script>
</BaseLayout>

<style>
body
{
    font-family: Carter One;

    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 60px); /* 扣掉頂部 header 的高度 */
    width: 100%;
    padding: 20px;
    box-sizing: border-box;
}

section
{
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    justify-content: center;
    align-items: center;
    max-width: 1200px;
    width: 100%;
}

/* header header header header header header header header header header */

.title-label h1
{
    font-family: Carter One;
    font-size: 1.5rem;
    
    position: absolute;
    left: 15px;
    top: 12px;

    margin: 0px;
}

#event-label
{
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    color: #faf9db;
    font-size: 3rem;
    margin-top: 15px;
    margin-bottom: clamp(5px, 2vh, 30px);
    padding: 0 10px;
}

/* aside aside aside aside aside aside aside aside aside aside */

.mode-toggle-container
{
    display: flex;
    gap: 10px;
}

.mode-btn-item
{
    flex: 1;
    background: #ffffff10;
    border: 1px solid #ffffff20;
    border-radius: 8px;
    color: #c5c5c5;
    padding: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s ease;
}

.mode-btn-item:hover
{
    background: #ffffff20;
    color: #faf9db;
}

.mode-btn-item.active
{
    background: #fffa65;
    border-color: #fffa65;
    color: #212836;
    font-weight: bold;
}

.menu-item
{
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.menu-item label
{
    font-size: 0.9rem;
    color: #c5c5c5;
}

#date-input, #title-input
{
    background: #ffffff10;
    border: 1px solid #ffffff20;
    border-radius: 8px;
    color: #faf9db;
    padding: 10px;
    font-size: 1rem;
    font-family: inherit;
    outline: none;
}

/* main main main main main main main main main main */

.time-box
{
    background: #ffffff10;
    padding: 15px 20px;
    border-radius: 30px;
    text-align: center;
    min-width: 100px;
    box-sizing: border-box;

    display: flex;
    flex-direction: column;
    align-items: center;
}

.time-box.mode-single
{
    min-width: 280px;
    width: auto;
    padding: 25px 30px;
}

/* 數字 */
.time-box div
{
    font-size: 2.5rem;
    font-weight: bold;
    color: #fffa65;

    width: max-content;
    /* 新增：強制數字等寬，防止字元縮放導致邊框抖動 */
    font-variant-numeric: tabular-nums;
}

.time-box.mode-single div
{
    font-size: 3.5rem;
    letter-spacing: 0.8rem;
}

/* 單位 */
.time-box span
{
    font-size: 0.8rem;
    color: #c5c5c5;
    display: block;
    margin: 5px;
    width: 55px;
}

.time-box.mode-single span
{
    font-size: 1.5rem;
}

/* footer footer footer footer footer footer footer footer footer footer */

#target-label
{
    color: #c5c5c5;
    align-items: center;
    font-size: 1rem;
    font-weight: bold;

    display: block;      /* 讓 margin 作用 */
    text-align: center;  /* 文字置中 */
    margin-top: clamp(15px, 3vh, 40px);
    width: 100%;         /* 強制換行，推開到倒數方塊下方 */
}

/* on moblie */

@media (max-width: 600px) 
{
    section
    {
        gap: 10px;
    }

    .time-box
    {
        padding: 10px 5px;
        border-radius: 15px;
    }

    .time-box div 
    {
        font-size: 1.6rem;
    }
    
    .time-box.mode-single
    {
        padding: 5px 15px;
    }
    
    .time-box.mode-single div
    {
        letter-spacing: 0.4rem;
    }

    .time-box.mode-single span
    {
        margin-top: -10px;
    }

}
</style>