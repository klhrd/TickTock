---
// src/pages/time-progress/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import timeProgressScript from "../../scripts/time-progress.js?url";
---

<BaseLayout>
    <div slot="head">
        <title>TickTock | Time Progress</title>
    </div>

    <div slot="header-content">
        <div id="header-time-overview" class="header-time-overview">
            Time Progress Dashboard
        </div>
    </div>

    <div slot="custom-menu">
        <div class="menu-intro">
            <label class="menu-section-label">Display Settings</label>
        </div>
        <div class="checkbox-group">
            <label class="checkbox-item">
                <input type="checkbox" value="year" checked class="progress-toggle">
                <span>Year Progress</span>
            </label>
            <label class="checkbox-item">
                <input type="checkbox" value="month" checked class="progress-toggle">
                <span>Month Progress</span>
            </label>
            <label class="checkbox-item">
                <input type="checkbox" value="day" checked class="progress-toggle">
                <span>Day Progress</span>
            </label>
            <label class="checkbox-item">
                <input type="checkbox" value="hour" checked class="progress-toggle">
                <span>Hour Progress</span>
            </label>
            <label class="checkbox-item">
                <input type="checkbox" value="minute" checked class="progress-toggle">
                <span>Minute Progress</span>
            </label>
            <label class="checkbox-item">
                <input type="checkbox" value="year" checked class="progress-toggle">
                <span>Year Progress</span>
            </label>
            <label class="checkbox-item">
                <input type="checkbox" value="second" checked class="progress-toggle">
                <span>second Progress</span>
            </label>
        </div>
    </div>

    <div slot="main-content" class="time-progress-container">
        
        <div class="progress-card" data-unit="year">
            <div class="info-header">
                <span class="card-title">Year</span>
                <span class="percent" id="pct-year">0%</span>
            </div>
            <div class="track-wrapper">
                <div class="thumb-tag" id="tag-year">0%</div>
                <div class="track">
                    <div class="bar" id="bar-year"></div>
                </div>
                <div class="thumb" id="thumb-year"></div>
            </div>
            <div class="ticks" id="ticks-year"></div>
        </div>

        <div class="progress-card" data-unit="month">
            <div class="info-header">
                <span class="card-title">Month</span>
                <span class="percent" id="pct-month">0%</span>
            </div>
            <div class="track-wrapper">
                <div class="thumb-tag" id="tag-month">0d</div>
                <div class="track">
                    <div class="bar" id="bar-month"></div>
                </div>
                <div class="thumb" id="thumb-month"></div>
            </div>
            <div class="ticks" id="ticks-month"></div>
        </div>

        <div class="progress-card" data-unit="day">
            <div class="info-header">
                <span class="card-title">Day</span>
                <span class="percent" id="pct-day">0%</span>
            </div>
            <div class="track-wrapper">
                <div class="thumb-tag" id="tag-day">0h</div>
                <div class="track">
                    <div class="bar" id="bar-day"></div>
                </div>
                <div class="thumb" id="thumb-day"></div>
            </div>
            <div class="ticks">
                <span>0</span>
                <span>6</span>
                <span>12</span>
                <span>18</span>
                <span>24h</span>
            </div>
        </div>

        <div class="progress-card" data-unit="hour">
            <div class="info-header">
                <span class="card-title">Hour</span>
                <span class="percent" id="pct-hour">0%</span>
            </div>
            <div class="track-wrapper">
                <div class="thumb-tag" id="tag-hour">0h</div>
                <div class="track">
                    <div class="bar" id="bar-hour"></div>
                </div>
                <div class="thumb" id="thumb-hour"></div>
            </div>
            <div class="ticks">
                <span>0</span>
                <span>15</span>
                <span>30</span>
                <span>45</span>
                <span>60m</span>
            </div>
        </div>

        <div class="progress-card" data-unit="minute">
            <div class="info-header">
                <span class="card-title">Minute</span>
                <span class="percent" id="pct-minute">0%</span>
            </div>
            <div class="track-wrapper">
                <div class="thumb-tag" id="tag-minute">0h</div>
                <div class="track">
                    <div class="bar" id="bar-minute"></div>
                </div>
                <div class="thumb" id="thumb-minute"></div>
            </div>
            <div class="ticks">
                <span>0</span>
                <span>15</span>
                <span>30</span>
                <span>45</span>
                <span>60s</span>
            </div>
        </div>

        <div class="progress-card" data-unit="second">
            <div class="info-header">
                <span class="card-title">Second</span>
                <span class="percent" id="pct-second">0%</span>
            </div>
            <div class="track-wrapper">
                <div class="thumb-tag" id="tag-second">0h</div>
                <div class="track">
                    <div class="bar" id="bar-second"></div>
                </div>
                <div class="thumb" id="thumb-second"></div>
            </div>
            <div class="ticks">
                <span>0</span>
                <span>250</span>
                <span>500</span>
                <span>750</span>
                <span>1000ms</span>
            </div>
        </div>

    </div>

    <div slot="footer-content"></div>
</BaseLayout>

<script
    slot="foot-script"
    type="module"
    src={timeProgressScript}
    is:inline>
</script>

<style>

body
{
    display: flex;
    align-items: center;
}

.checkbox-group
{
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 10px;
}

.checkbox-item
{
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--component-bg-standard);
    font-size: 0.95rem;
    cursor: pointer;
    padding: 6px 10px;
    border-radius: 8px;
    transition: background 0.2s ease, color 0.2s ease;
}

.checkbox-item:hover
{
    background: var(--component-bg-hover);
    color: var(--text-body);
}

.checkbox-item input[type="checkbox"]
{
    accent-color: var(--accent-color);
    width: 16px;
    height: 16px;
    cursor: pointer;
}

.checkbox-item span
{
    color: var(--text-dimmed);
}

.checkbox-item:hover span
{
    color: var(--text-secondary);
}

.time-progress-container
{
    width: fit-content;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0;
}

.progress-card
{
    background: var(--component-bg-standard);
    border: 1px solid var(--border-subtle);
    padding: 1.2rem 1.5rem;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    width: 65svw;
}

.progress-card.hidden
{
    display: none;
}

.info-header
{
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.8rem;
}

.card-title
{
    font-weight: 600;
    color: var(--text-heading);
    font-size: 1rem;
}

.percent
{
    font-family: monospace;
    font-weight: bold;
    color: var(--accent-color);
}

.track-wrapper
{
    position: relative;
    width: 100%;
    margin-bottom: 0.5rem;
}

.track
{
    width: 100%;
    height: 12px;
    background: var(--button-secondary-bg);
    border-radius: 6px;
    position: relative;
    overflow: hidden;
}

.bar
{
    height: 100%;
    width: 0%;
    background: var(--accent-color);
    border-radius: 6px;
    transition: width 0.1s linear;
}

#bar-second
{
    transition: width 0s linear !important;
}

.thumb-tag
{
    position: absolute;
    top: -28px;
    transform: translateX(-50%);
    background: var(--accent-color);
    color: var(--accent-contract-text);
    font-size: 0.75rem;
    font-weight: bold;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: monospace;
    white-space: nowrap;
    pointer-events: none;
}

.thumb-tag::after
{
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 4px 4px 0;
    border-style: solid;
    border-color: var(--accent-color) transparent;
}

.thumb
{
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 18px;
    height: 18px;
    background-color: var(--text-body);
    border: 3px solid var(--accent-color);
    border-radius: 50%; /* circle */
    box-shadow: 0 0 8px var(--accent-bg-alpha);
    pointer-events: none;
}

.ticks
{
    display: flex;
    justify-content: space-between;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-family: monospace;
    padding: 0 2px;
}

</style>