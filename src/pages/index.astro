---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
    <div slot="head">
        <title>TickTock | Multi-Tool Hub</title>
    </div>

    <div slot="header-content">
        <div class="title-label">
            <h1>Tick Tock</h1>
        </div>
    </div>

    <div slot="custom-menu">
        <div class="menu-intro">
            <h3>Welcome</h3>
            <p>Select a tool from the directory below or use the quick links on the dashboard.</p>
        </div>
    </div>

    <div slot="main-content" class="home-container">
        <header class="hero">
            <h2>TickTock Tool Hub</h2>
            <p>Simplifying your time management with clean, functional tools.</p>
        </header>

        <section class="tool-grid">
            <a href="/TickTock/countdown" class="tool-card">
                <div class="card-icon">
                    <span class="material-symbols-outlined">calendar_clock</span>
                </div>

                <div class="card-info">
                    <h3>Countdown Timer</h3>
                    <p>Track your important events with custom target dates.</p>
                </div>
            </a>

            <a href="/TickTock/digital-clock" class="tool-card">
                <div class="card-icon">
                    <span class="material-symbols-outlined">nest_clock_farsight_digital</span>
                </div>

                <div class="card-info">
                    <h3>Digital Clock</h3>
                    <p>A beautiful digital clock with customizable formats and fonts.</p>
                </div>
            </a>
            
            <div class="tool-card coming-soon">
                <div class="card-icon">
                    <span class="material-symbols-outlined">more_horiz</span>
                </div>

                <div class="card-info">
                    <h3>More Coming Soon</h3>
                    <p>Stay tuned for Clock, Timer, and Stopwatch tools.</p>
                </div>
            </div>
            <div class="tool-card coming-soon">
                <div class="card-icon">
                    <span class="material-symbols-outlined">more_horiz</span>
                </div>

                <div class="card-info">
                    <h3>More Coming Soon</h3>
                    <p>Stay tuned for Clock, Timer, and Stopwatch tools.</p>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<style>
* 
{
    box-sizing: border-box; /* 確保所有元素的 padding 不會撐開寬度 */
}

body 
{
    margin: 0;   /* 關鍵：清除瀏覽器內建的外邊距 */
    padding: 0;
}

.home-container
{
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    width: 100svw;             /* 建議將 100svw 改為 100%，對瀏覽器相容性更好 */
    box-sizing: border-box;   /* 關鍵：讓 padding 包含在 100% 寬度內，不爆出螢幕 */
    overflow-x: hidden;      /* 保險：防止任何意外的水平捲軸 */
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: calc(100vh - 60px);
}

.title-label h1
{
    font-family: Carter One;
    font-size: 1.5rem;
    position: absolute;
    left: 15px;
    top: 12px;
    margin: 0;
}

.hero
{
    text-align: center;
    margin-bottom: 40px;
}

.hero h2
{
    font-family: Carter One;
    font-size: 3rem;
    color: #fffa65;
    margin-bottom: 10px;
}

.hero p
{
    color: #c5c5c5;
    font-size: 1.1rem;
}

.tool-grid
{
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 25px;

    width: 100%;
    max-width: 1200px;
}

.tool-card
{
    background: #ffffff08;
    border: 1px solid #ffffff15;
    border-radius: 20px;
    padding: 30px;
    display: flex;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    transition: all 0.3s ease;

    width: 100%;             /* 讓卡片寬度百分之百服從 Grid 的分配 */
    box-sizing: border-box;   /* 確保卡片內襯 padding 不會撐大卡片 */
}

.tool-card:hover
{
    background: #ffffff12;
    border-color: #fffa65;
    cursor: pointer;
    transform: translateY(-5px);
}

.card-icon
{
    background: #fffa6520;
    width: 60px;
    height: 60px;
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;

    flex-shrink: 0;
}

.card-icon .material-symbols-outlined
{
    color: #faf9db;
    font-size: 2rem;
}

.card-info h3
{
    color: #faf9db;
    margin: 0 0 5px 0;
    font-size: 1.2rem;
}

.card-info p
{
    color: #aaaaaa;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.4;
}

.coming-soon
{
    opacity: 0.5;
    cursor: default;
}

.coming-soon:hover
{
    transform: none;
    border-color: #ffffff15;
}

.menu-intro h3
{
    margin-top: 0;
    color: #fffa65;
}

.menu-intro p
{
    font-size: 0.85rem;
    color: #aaaaaa;
    line-height: 1.6;
}

@media (max-width: 600px)
{
    .hero h2
    {
        font-size: 2rem;
    }
}

</style>

<script is:inline>
    if(typeof window !=="undefined" && typeof document !=="undefined")
    {
        const shareMenuBtn=document.getElementById("share-menu-btn");

        shareMenuBtn?.addEventListener("click",async()=>
        {
            const shareData=
            {
                title: "TickTock | Multi-Tool Hub",
                text: "Simplifying your time management with clean, functional tools.",
                url: window.location.href
            };

            try
            {
                if(navigator.share)
                {
                    await navigator.share(shareData);
                }
                else
                {
                    await navigator.clipboard.writeText(window.location.href);

                    const icon=shareMenuBtn.querySelector(".material-symbols-outlined");
                
                    if(icon)
                    {
                        icon.innerText="check";
                        shareMenuBtn.style.color="#fffa65"

                        setTimeout(()=>
                        {
                            icon.innerText="share";
                            shareMenuBtn.style.color="";
                        },2000);
                    }
                }
            }
            catch(err)
            {
                console.log("Fail to Share: ", err);
            }
        });
    }
</script>