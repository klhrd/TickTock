---
// src/pages/digital-clock/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import clockScript from "../../scripts/digital-clock.js?url";
---

<BaseLayout>
    <div slot="head">
        <title>TickTock | Clock</title>
    </div>

    <div slot="header-content">
        <div id="date-label"></div>
    </div>

    <div slot="custom-menu">
        <div class="menu-item">
            <label>Time Format</label>
            <div class="toggle-container">
                <button id="btn-24hr" class="toggle-btn active">24hr</button>
                <button id="btn-12hr" class="toggle-btn">12hr</button>
            </div>
        </div>

        <div class="menu-item" style="margin-top: 15px;">
            <label>Font Style</label>
            <div id="font-selector">
                <button id="font-sans" class="font-btn active">Modern Sans</button>
                <button id="font-serif" class="font-btn">Classic Serif</button>
                <button id="font-mono" class="font-btn">Tech Mono</button>
            </div>
        </div>

        <div class="menu-item" style="margin-top: 15px;">
            <label>Display Mode</label>
            <div class="toggle-container">
                <button id="btn-fullscreen-exit" class="toggle-btn active"><span class="material-symbols-outlined">fullscreen_exit</span></button>
                <button id="btn-fullscreen" class="toggle-btn"><span class="material-symbols-outlined">fullscreen</span></button>
            </div>
        </div>
    </div>

    <div slot="main-content" class="clock-container" id="clock-screen">
        <div class="time-container">
            <span id="txt-hours" class="time-text">00</span>
            <span class="colon">:</span>
            <span id="txt-minutes" class="time-text">00</span>
            <span class="colon">:</span>
            <span id="txt-seconds" class="time-text">00</span>
        </div>
    </div>

    <div slot="footer-content">
        <span id="txt-ampm" class="ampm-label"></span>
    </div>
</BaseLayout>

<script
    slot="foot-script"
    type="module"
    src={clockScript}>
</script>

<style>
:root
{
    --clock-font: ui-sans-serif, system-ui, sans-serif;
    --clock-colon-width:clamp(1rem, calc(7vw - 1.2rem), 8rem);
}

/* ==========================================================================
   當 HTML 最頂層進入全螢幕時的版面修正
   ========================================================================== */
:root:fullscreen,
:root:-webkit-full-screen 
{
    background-color: #212836 !important;
}

/* 確保全螢幕下，整頁的 Layout 容器高度撐滿，且不會隱藏/剪裁子元素 */
:root:fullscreen body,
:root:-webkit-full-screen body
{
    height: 100vh !important;
    display: flex !important;
    flex-direction: column !important;
    overflow: hidden !important; /* 防止出現滾動條 */
}

/* 確保時鐘主容器在全螢幕下，會自動伸縮，把 header 與 footer 撐到兩端 */
:root:fullscreen .time-container,
:root:-webkit-full-screen .time-container
{
    flex: 1 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 0 !important;
}

/* 確保全螢幕下，Header 與 Footer 的 Z-Index 在最上層，且維持正常高度 */
:root:fullscreen header,
:root:-webkit-full-screen header,
:root:fullscreen footer,
:root:-webkit-full-screen footer,
:root:fullscreen .menu-btn,
:root:-webkit-full-screen .menu-btn
{
    position: relative !important;
    z-index: 100 !important; /* 確保不會被時鐘的背景色蓋過去 */
    display: flex !important; /* 強制顯示，避免被其他 CSS 隱藏 */
}

#date-label,
.clock-container,
#txt-ampm,
.menu-item,
#font-selector
{
    font-family: var(--clock-font) !important;
}

/* header header header header header header header header header header */

#date-label
{
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    color: #faf9db;
    font-size: clamp(0.5rem, calc(8vw - 1.2rem), 3rem);
    margin-top: clamp(-8px, calc(12.5vh - 36.25px), 30px);
    margin-bottom: clamp(-8px, calc(12.5vh - 36.25px), 30px);
    padding: 0 10px;
}

/* aside aside aside aside aside aside aside aside aside aside */

.toggle-container
{
    display: flex;
    gap: 10px;
}

.toggle-btn
{
    flex: 1;
    background: #ffffff10;
    border: 1px solid #ffffff20;
    border-radius: 8px;
    color: #c5c5c5;
    padding: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s ease;

    display: flex;
    justify-content: center;
    align-items: center;
}

.toggle-btn:hover
{
    background: #ffffff20;
    color: #faf9db;
}

.toggle-btn.active
{
    background: #fffa65;
    border-color: #fffa65;
    color: #212836;
    font-weight: bold;
}

.menu-item
{
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.menu-item label
{
    font-size: 0.9rem;
    color: #c5c5c5;
}

#font-selector
{
    display: flex;
    gap: 10px;
    flex-direction: column;
}

.font-btn
{
    flex: none;
    background: #ffffff10;
    border: 1px solid #ffffff20;
    border-radius: 8px;
    color: #c5c5c5;
    padding: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s ease;
}

.font-btn:hover
{
    background: #ffffff20;
    color: #faf9db;
}

.font-btn.active
{
    background: #fffa65;
    border-color: #fffa65;
    color: #212836;
    font-weight: bold;
}

/* 預設現代無襯線字 (Modern Sans) */
#font-sans
{
    font-family: ui-sans-serif, system-ui, sans-serif;
}

/* 古典襯線字 (Classic Serif) */
#font-serif
{
    font-family: ui-serif, Georgia, serif;
}

/* 科技等寬字 (Tech Mono) */
#font-mono
{
    font-family: ui-monospace, monospace;
}

/* main main main main main main main main main main */

.time-container
{
    font-family: var(--clock-font);
    background: #ffffff00;
    padding: 0px 20px;
    border-radius: 30px;
    text-align: center;
    min-width: 100px;
    box-sizing: border-box;
    height: auto;

    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
}

/* 數字 */
.time-text
{
    font-size: clamp(2rem, calc(20vw - 0.5rem), 12rem);
    font-weight: bold;
    color: #fffa65;

    width: max-content;
    /* 新增：強制數字等寬，防止字元縮放導致邊框抖動 */
    font-variant-numeric: tabular-nums;

    display: inline-block;
    text-align: center;
    min-width: 2.2ch;
}

/* 冒號 */
.colon
{
    font-size: clamp(1rem, calc(12vw - 1.5rem), 8rem);
    color: #c5c5c5;
    display: block;
    margin: 5px;
    
    width: var(--clock-colon-width);
}

/* footer footer footer footer footer footer footer footer footer footer */

#txt-ampm
{
    color: #c5c5c5;
    align-items: center;
    font-size: clamp(0.5rem, calc(8vw - 1.2rem), 3rem);
    font-weight: normal;

    display: block;      /* 讓 margin 作用 */
    text-align: center;  /* 文字置中 */
    margin-top: clamp(-8px, calc(12.5vh - 40px), 30px);
    width: 100%;         /* 強制換行，推開到倒數方塊下方 */
}

/* on moblie */

@media (max-width: 600px) 
{

    .time-container
    {
        padding: 10px 5px;
        border-radius: 15px;
    }

    /* 
    .time-text
    {
        font-size: 4rem;
    }

    .colon
    {
        font-size: 2rem;
    }
    */
}
</style>