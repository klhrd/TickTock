---
// src/pages/clock/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import clockScript from "../../scripts/clock.js?url";
---

<BaseLayout>
    <div slot="head">
        <title>TickTock | Clock</title>
    </div>

    <div slot="header-content">
        <div class="title-label">
            <h1>TickTock</h1>
        </div>
        <div id="date-label"></div>
    </div>

    <div slot="custom-menu">
        <div class="menu-item">
            <label>Time Format</label>
            <div class="toggle-container">
                <button id="btn-24hr" class="toggle-btn active">24hr</button>
                <button id="btn-12hr" class="toggle-btn">12hr</button>
            </div>
        </div>

        <div class="menu-item" style="margin-top: 15px;">
            <label>Font Style</label>
            <div id="font-selector">
                <button id="font-sans" class="font-btn active">Modern Sans</button>
                <button id="font-serif" class="font-btn">Classic Serif</button>
                <button id="font-mono" class="font-btn">Tech Mono</button>
            </div>
        </div>

        <div class="menu-item" style="margin-top: 15px;">
            <label>Display Mode</label>
            <div class="toggle-container">
                <button id="btn-fullscreen-exit" class="toggle-btn active"><span class="material-icons">fullscreen_exit</span></button>
                <button id="btn-fullscreen" class="toggle-btn"><span class="material-icons">fullscreen</span></button>
            </div>
        </div>
    </div>

    <div slot="main-content" class="clock-container" id="clock-screen">
        <div class="time-container">
            <span id="txt-hours" class="time-text">00</span>
            <span class="colon">:</span>
            <span id="txt-minutes" class="time-text">00</span>
            <span class="colon">:</span>
            <span id="txt-seconds" class="time-text">00</span>
        </div>
    </div>

    <div slot="footer-content">
        <span id="txt-ampm" class="ampm-label"></span>
    </div>
</BaseLayout>

<script
    slot="foot-script"
    type="module"
    src={clockScript}>
</script>

<style>
section
{
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    justify-content: center;
    align-items: center;
    max-width: 1200px;
    width: 100%;
}

/* header header header header header header header header header header */

.title-label h1
{
    font-family: Carter One;
    font-size: 1.5rem;
    
    position: absolute;
    left: 15px;
    top: 12px;

    margin: 0px;
}

#date-label
{
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    color: #faf9db;
    font-size: 2rem;
    margin-top: 15px;
    margin-bottom: 0;
    padding: 0 10px;
}

/* aside aside aside aside aside aside aside aside aside aside */

.toggle-container
{
    display: flex;
    gap: 10px;
}

.toggle-btn
{
    flex: 1;
    background: #ffffff10;
    border: 1px solid #ffffff20;
    border-radius: 8px;
    color: #c5c5c5;
    padding: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s ease;

    display: flex;
    justify-content: center;
    align-items: center;
}

.toggle-btn:hover
{
    background: #ffffff20;
    color: #faf9db;
}

.toggle-btn.active
{
    background: #fffa65;
    border-color: #fffa65;
    color: #212836;
    font-weight: bold;
}

.menu-item
{
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.menu-item label
{
    font-size: 0.9rem;
    color: #c5c5c5;
}

#font-selector
{
    display: flex;
    gap: 10px;
    flex-direction: column;
}

.font-btn
{
    flex: none;
    background: #ffffff10;
    border: 1px solid #ffffff20;
    border-radius: 8px;
    color: #c5c5c5;
    padding: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s ease;
}

.font-btn:hover
{
    background: #ffffff20;
    color: #faf9db;
}

.font-btn.active
{
    background: #fffa65;
    border-color: #fffa65;
    color: #212836;
    font-weight: bold;
}

/* 預設現代無襯線字 (Modern Sans) */
#font-sans
{
    font-family: ui-sans-serif, system-ui, sans-serif;
}

/* 古典襯線字 (Classic Serif) */
#font-serif
{
    font-family: ui-serif, Georgia, serif;
}

/* 科技等寬字 (Tech Mono) */
#font-mono
{
    font-family: ui-monospace, monospace;
}

/* main main main main main main main main main main */

.time-container
{
    background: #ffffff00;
    padding: 0px 20px;
    border-radius: 30px;
    text-align: center;
    min-width: 100px;
    box-sizing: border-box;

    display: flex;
    flex-direction: row;
    align-items: center;
}

/* 數字 */
.time-text
{
    font-size: 9rem;
    font-weight: bold;
    color: #fffa65;

    width: max-content;
    /* 新增：強制數字等寬，防止字元縮放導致邊框抖動 */
    font-variant-numeric: tabular-nums;
}

/* 冒號 */
.colon
{
    font-size: 4.5rem;
    color: #c5c5c5;
    display: block;
    margin: 5px;
    width: 55px;
}

/* footer footer footer footer footer footer footer footer footer footer */

#txt-ampm
{
    color: #c5c5c5;
    align-items: center;
    font-size: 2rem;
    font-weight: normal;

    display: block;      /* 讓 margin 作用 */
    text-align: center;  /* 文字置中 */
    margin-top: 0;
    width: 100%;         /* 強制換行，推開到倒數方塊下方 */
}

/* on moblie */

@media (max-width: 600px) 
{
    section
    {
        gap: 10px;
    }

    .time-container
    {
        padding: 10px 5px;
        border-radius: 15px;
    }

    .time-container span
    {
        font-size: 1.6rem;
    }
}
</style>